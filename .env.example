# Reference only - secrets are managed via Infisical.
# Use ./scripts/export-secrets.sh [dev|prod] to generate .env,
# or ./rundev.sh / ./runprod.sh which export automatically.
# If running without Infisical, copy to .env and fill in values manually.

# Shared
GUILD_ID=
DOMAIN=

# Role IDs (shared across bots)
STAFF_ROLE_ID=
SENIOR_STAFF_ROLE_ID=
OWNER_ROLE_ID=
MENTOR_ROLE_ID=

# MongoDB
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=foundry

# PostgreSQL
POSTGRES_USER=foundry
POSTGRES_PASSWORD=
POSTGRES_DB=foundry
# Note: special chars in POSTGRES_PASSWORD must be percent-encoded (@ → %40, % → %25, etc.)

# Valkey / Redis
VALKEY_URI=redis://valkey:6379

# Discord bot tokens (each bot needs its own application/token)
DISCORD_SERVER_TOKEN=
DISCORD_UTILS_TOKEN=
DISCORD_EVENT_TOKEN=

# Wise Old Man - RSN name change tracking (optional)
# Set WOM_GROUP_ID to enable; leave blank to disable the service
WOM_GROUP_ID=
WOM_GROUP_KEY=
WOM_API_KEY=
WOM_CLAN_NAME=Iron Foundry
WOM_DISCORD_CONTACT=

# Discord OAuth2 (for web-app login)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://api.ironfoundry.cc/auth/callback

# Web app
FRONTEND_URL=https://ironfoundry.cc,http://localhost:3000
API_BACKEND_URL=https://api.ironfoundry.cc
# Dev only: overrides the API the local frontend talks to (defaults to http://localhost:8000)
BUN_PUBLIC_API_URL=http://localhost:8000
JWT_SECRET=

# UploadThing - permanent image hosting for ticket transcripts (optional)
# Obtain from https://uploadthing.com/dashboard -> API Keys
# Leave blank to disable; Discord CDN links will be stored as-is (they expire)
UPLOADTHING_SECRET=

# Party system - Discord webhook for party announcements (optional)
# Create a webhook in your party announcements channel and paste the full URL here.
# Leave blank to disable Discord integration for parties.
DISCORD_PARTY_WEBHOOK_URL=

# Metrics reporting - shared key used by all services that POST to /metrics/report.
# Set to any strong random string. Must be identical across api-backend and all reporting services.
METRICS_API_KEY=
