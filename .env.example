# Copy to .env and fill in values before running docker compose

# Shared
GUILD_ID=
DOMAIN=

# Role IDs (shared across bots)
STAFF_ROLE_ID=
SENIOR_STAFF_ROLE_ID=
OWNER_ROLE_ID=
MENTOR_ROLE_ID=

# MongoDB
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=foundry

# Valkey / Redis
VALKEY_URI=redis://valkey:6379

# Discord bot tokens (each bot needs its own application/token)
DISCORD_SERVER_TOKEN=
DISCORD_UTILS_TOKEN=
DISCORD_EVENT_TOKEN=

# Wise Old Man — RSN name change tracking (optional)
# Set WOM_GROUP_ID to enable; leave blank to disable the service
WOM_GROUP_ID=
WOM_GROUP_KEY=
WOM_CLAN_NAME=Iron Foundry

# Discord OAuth2 (for web-app login)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://api.ironfoundry.cc/auth/callback

# Web app
FRONTEND_URL=https://ironfoundry.cc,http://localhost:3000
API_BACKEND_URL=https://api.ironfoundry.cc
JWT_SECRET=
